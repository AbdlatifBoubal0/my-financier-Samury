# ---------------------------------------------------------------
# Copy to .env and fill in real values. NEVER commit .env
# Spring Boot reads these via ${VAR} placeholders in
# application.properties. Frontend vars are read by Vite.
# ---------------------------------------------------------------

# ===== Backend (Spring Boot) =====

# --- Server ---
SERVER_PORT=8080
APP_CLIENT_URL=http://localhost:5173

# --- Database (MySQL) ---
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/my_financier
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# --- JWT / Auth ---
JWT_SECRET=
JWT_ACCESS_EXPIRATION=900000          # 15 min (ms)
JWT_REFRESH_EXPIRATION=604800000      # 7 days (ms)
COOKIE_SECURE=false                   # true in production (HTTPS)
COOKIE_SAME_SITE=Lax

# --- Mail (email verification, reports) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# --- File storage ---
STORAGE_LOCATION=./uploads
STORAGE_MAX_FILE_SIZE=5MB

# --- Zakat / gold price ---
GOLD_API_BASE_URL=https://www.goldapi.io
GOLD_API_KEY=
ZAKAT_NISAB_GOLD_GRAMS=85

# --- Money / locale defaults ---
DEFAULT_CURRENCY=MAD
APP_TIMEZONE=Africa/Casablanca

# ===== Frontend (Vite) =====
VITE_API_BASE_URL=http://localhost:8080/api
VITE_DEFAULT_LOCALE=en
